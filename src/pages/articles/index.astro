---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}
---

<BaseLayout
  title="Articles"
  description="All articles by Nikita Fomin — technical notes on ML, LLMs, engineering, and research."
>
  <div class="container articles-page">
    <h1 class="page-title">Articles</h1>
    <p class="page-description">
      Technical notes, ML/LLM experiments, engineering write-ups, and research summaries.
    </p>

    {articles.length === 0 ? (
      <p style="color: var(--text-secondary); font-family: var(--font-ui);">No articles yet.</p>
    ) : (
      <ul class="article-list">
        {articles.map(article => (
          <li class="article-card">
            <div>
              <a href={`/articles/${article.id}`} class="article-card__title">
                {article.data.title}
              </a>
              <p class="article-card__description">{article.data.description}</p>
              {article.data.tags && article.data.tags.length > 0 && (
                <div class="article-card__tags">
                  {article.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </div>
            <div class="article-card__meta">
              <div class="article-card__date">{formatDate(article.data.date)}</div>
              <div class="article-card__reading-time">{readingTime(article.body ?? '')} min read</div>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
